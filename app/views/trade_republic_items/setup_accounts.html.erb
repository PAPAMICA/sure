<% content_for :title, t("trade_republic_items.setup_accounts.title", default: "Link Trade Republic sub-portfolios") %>

<%= render DS::Dialog.new(disable_click_outside: true) do |dialog| %>
  <% dialog.with_header(title: t("trade_republic_items.setup_accounts.title", default: "Link sub-portfolios")) do %>
    <div class="flex items-center gap-2">
      <%= icon "trending-up", class: "text-primary" %>
      <span class="text-primary"><%= t("trade_republic_items.setup_accounts.subtitle", default: "Create Sure accounts for each Trade Republic line") %></span>
    </div>
  <% end %>

  <% dialog.with_body do %>
    <div class="space-y-6">
      <div class="bg-surface border border-primary p-4 rounded-lg">
        <p class="text-sm text-primary">
          <%= t("trade_republic_items.setup_accounts.instructions", default: "Checked lines will become new Sure accounts with the suggested type (PEA → Investment, cash → Depository, etc.).") %>
        </p>
      </div>

      <%= form_with url: complete_account_setup_trade_republic_item_path(@trade_republic_item),
                    method: :post,
                    data: {
                      controller: "loading-button",
                      action: "submit->loading-button#showLoading",
                      turbo_frame: "_top"
                    } do %>

        <% if @unlinked_accounts.any? %>
          <div class="space-y-4">
            <% @unlinked_accounts.each do |tra| %>
              <div class="border border-primary rounded-lg p-4">
                <div class="flex items-center gap-3">
                  <input type="checkbox" id="tra_<%= tra.id %>" name="account_ids[]" value="<%= tra.id %>" checked class="cursor-pointer">
                  <label for="tra_<%= tra.id %>" class="flex-1 cursor-pointer">
                    <h4 class="font-medium text-primary"><%= tra.name %></h4>
                    <p class="text-sm text-secondary">
                      <%= tra.suggested_accountable_type %> ·
                      <%= number_to_currency(tra.current_balance || 0, unit: Money::Currency.new(tra.currency || "EUR").symbol) %>
                    </p>
                  </label>
                </div>
              </div>
            <% end %>
          </div>

          <div class="flex gap-3 mt-6">
            <%= render DS::Button.new(
              text: t("trade_republic_items.setup_accounts.import_selected", default: "Create linked accounts"),
              variant: "primary",
              icon: "plus",
              type: "submit",
              class: "flex-1",
              data: { loading_button_target: "button" }
            ) %>
            <%= render DS::Link.new(
              text: t("trade_republic_items.select_existing_account.cancel_button"),
              variant: "secondary",
              href: accounts_path,
              frame: "_top"
            ) %>
          </div>
        <% else %>
          <p class="text-center text-secondary py-6"><%= t("trade_republic_items.setup_accounts.no_accounts", default: "Nothing to link. Try syncing again from provider settings.") %></p>
          <%= render DS::Link.new(
            text: t("trade_republic_items.select_existing_account.cancel_button"),
            variant: "secondary",
            href: accounts_path,
            frame: "_top"
          ) %>
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>
