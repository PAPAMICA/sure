<%= content_for :page_title, t("trade_republic_items.panel.title") %>

<div class="space-y-6 max-w-2xl">
  <div class="flex flex-wrap gap-3">
    <%= link_to t("trade_republic_items.panel.manage"), settings_providers_path, class: "btn btn--secondary" %>
    <%= button_to t("trade_republic_items.show.sync_now", default: "Sync now"), sync_trade_republic_item_path(@trade_republic_item), class: "btn btn--primary" %>
    <%= button_to t("trade_republic_items.panel.disconnect"), disconnect_trade_republic_item_path(@trade_republic_item), method: :post, class: "btn btn--destructive", data: { turbo_confirm: t("trade_republic_items.panel.disconnect_confirm", default: "Disconnect Trade Republic?") } %>
  </div>

  <div class="border border-primary rounded-lg divide-y divide-primary">
    <% @trade_republic_item.trade_republic_accounts.order(:name).each do |tra| %>
      <div class="p-4 flex justify-between gap-4">
        <div>
          <p class="font-medium text-primary"><%= tra.name %></p>
          <p class="text-sm text-secondary"><%= tra.portfolio_type %> · <%= tra.currency %></p>
        </div>
        <p class="text-primary font-medium tabular-nums">
          <%= number_to_currency(tra.current_balance || 0, unit: "") %> <%= tra.currency %>
        </p>
      </div>
    <% end %>
  </div>
</div>
