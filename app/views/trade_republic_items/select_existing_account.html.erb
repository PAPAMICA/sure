<% content_for :title, t("trade_republic_items.select_existing_account.title", account_name: @account.name) %>

<%= render DS::Dialog.new do |dialog| %>
  <% dialog.with_header(title: t("trade_republic_items.select_existing_account.header")) do %>
    <div class="flex items-center gap-2">
      <%= icon "link", class: "text-primary" %>
      <span class="text-primary"><%= t("trade_republic_items.select_existing_account.subtitle", account_name: @account.name) %></span>
    </div>
  <% end %>

  <% dialog.with_body do %>
    <% if @trade_republic_accounts.blank? %>
      <div class="text-center py-8">
        <%= icon "alert-circle", class: "text-warning mx-auto mb-4", size: "lg" %>
        <p class="text-secondary"><%= t("trade_republic_items.select_existing_account.no_accounts") %></p>
        <p class="text-sm text-secondary mt-2"><%= t("trade_republic_items.select_existing_account.connect_hint") %></p>
        <%= link_to t("trade_republic_items.select_existing_account.settings_link"), settings_providers_path, class: "btn btn--primary btn--sm mt-4" %>
      </div>
    <% else %>
      <div class="bg-surface border border-primary p-4 rounded-lg mb-4">
        <p class="text-sm text-primary">
          <strong><%= t("trade_republic_items.select_existing_account.linking_to") %></strong>
          <%= @account.name %>
        </p>
      </div>

      <% @trade_republic_accounts.each do |tra| %>
        <%= form_with url: link_existing_account_trade_republic_items_path,
                      method: :post,
                      local: true,
                      class: "border border-primary rounded-lg p-4 hover:bg-surface transition-colors mb-3" do %>
          <%= hidden_field_tag :account_id, @account.id %>
          <%= hidden_field_tag :trade_republic_item_id, @trade_republic_item.id %>
          <%= hidden_field_tag :trade_republic_account_id, tra.id %>

          <div class="flex items-center justify-between">
            <div>
              <h4 class="font-medium text-primary"><%= tra.name %></h4>
              <p class="text-sm text-secondary">
                <%= t("trade_republic_items.select_existing_account.balance_label") %>
                <%= number_to_currency(tra.current_balance || 0, unit: Money::Currency.new(tra.currency || "EUR").symbol) %>
              </p>
            </div>
            <%= render DS::Button.new(
              text: t("trade_republic_items.select_existing_account.link_button"),
              variant: "primary",
              size: "sm",
              type: "submit"
            ) %>
          </div>
        <% end %>
      <% end %>

      <div class="mt-6">
        <%= render DS::Link.new(
          text: t("trade_republic_items.select_existing_account.cancel_button"),
          variant: "secondary",
          href: account_path(@account)
        ) %>
      </div>
    <% end %>
  <% end %>
<% end %>
