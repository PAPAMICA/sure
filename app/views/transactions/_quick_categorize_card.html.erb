<%# locals: (entry:, transaction:, categories:) %>
<% perm = entry && entry.account.permission_for(Current.user) %>
<% full_edit = perm && perm.in?(%i[owner full_control]) %>
<% can_note = perm && perm.in?(%i[owner full_control read_write]) %>
<% if entry.blank? %>
  <div class="bg-container rounded-xl shadow-border-xs p-8 text-center space-y-3">
    <p class="text-primary font-medium"><%= t("transactions.quick_categorize.all_done_title") %></p>
    <p class="text-secondary text-sm"><%= t("transactions.quick_categorize.all_done_body") %></p>
    <%= render DS::Link.new(
      text: t("transactions.quick_categorize.back_to_list"),
      href: transactions_path,
      variant: "primary"
    ) %>
  </div>
<% else %>
  <div class="bg-container rounded-xl shadow-border-xs p-5 space-y-6"
       data-controller="quick-categorize"
       data-quick-categorize-autosave-url-value="<%= transaction_path(entry) %>"
       data-quick-categorize-transaction-id-value="<%= transaction.id %>">
    <div class="space-y-1">
      <p class="text-xs font-medium text-secondary uppercase tracking-wide"><%= t("transactions.quick_categorize.card_heading") %></p>
      <p class="text-lg text-primary font-medium"><%= entry.name %></p>
      <p class="text-2xl font-semibold text-primary">
        <%= Money.new(entry.amount, entry.currency).format %>
      </p>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-secondary">
        <span><%= l(entry.date, format: :long) %></span>
        <span><%= entry.account.name %></span>
        <% if transaction.merchant %>
          <span><%= transaction.merchant.name %></span>
        <% end %>
      </div>
    </div>

    <% if full_edit %>
      <div class="space-y-3">
        <%= label_tag "entry_name", t("transactions.quick_categorize.name_label"), class: "text-sm font-medium text-primary" %>
        <%= text_field_tag "entry[name]", entry.name,
              id: "entry_name",
              class: "form-field__input w-full",
              autocomplete: "off",
              data: {
                quick_categorize_target: "name",
                action: "input->quick-categorize#scheduleSave"
              } %>
        <%= label_tag "entry_notes", t("transactions.quick_categorize.notes_label"), class: "text-sm font-medium text-primary" %>
        <%= text_area_tag "entry[notes]", entry.notes,
              id: "entry_notes",
              rows: 2,
              class: "form-field__input w-full",
              data: {
                quick_categorize_target: "notes",
                action: "input->quick-categorize#scheduleSave"
              } %>
      </div>
    <% elsif can_note %>
      <div class="space-y-3">
        <%= label_tag "entry_notes", t("transactions.quick_categorize.notes_label"), class: "text-sm font-medium text-primary" %>
        <%= text_area_tag "entry[notes]", entry.notes,
              id: "entry_notes",
              rows: 2,
              class: "form-field__input w-full",
              data: {
                quick_categorize_target: "notes",
                action: "input->quick-categorize#scheduleSave"
              } %>
      </div>
    <% end %>

    <div class="space-y-3">
      <label for="quick_categorize_search" class="text-sm font-medium text-primary"><%= t("transactions.quick_categorize.pick_category") %></label>
      <%= text_field_tag :q, "",
            id: "quick_categorize_search",
            type: "search",
            autocomplete: "off",
            class: "form-field__input w-full",
            placeholder: t("transactions.quick_categorize.search_placeholder"),
            data: {
              quick_categorize_target: "search",
              action: "input->quick-categorize#filter keydown->quick-categorize#searchKeydown"
            } %>

      <div class="flex flex-wrap gap-1.5">
        <% categories.each do |category| %>
          <div class="inline-block"
               data-quick-categorize-target="categoryRow"
               data-category-name="<%= h(category.name.to_s.downcase) %>">
            <%= button_to transaction_category_path(
                  entry,
                  quick_categorize: "1",
                  entry: {
                    entryable_type: "Transaction",
                    entryable_attributes: { id: transaction.id, category_id: category.id }
                  }
                ),
                method: :patch,
                data: { turbo_frame: "quick_categorize_card" },
                class: "inline-flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-sm text-primary hover:bg-surface-hover" do %>
              <% if category.lucide_icon.present? %>
                <span style="color: <%= category.color %>">
                  <%= icon category.lucide_icon, size: "sm", color: "current" %>
                </span>
              <% end %>
              <span style="color: <%= category.color %>"><%= category.name %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
