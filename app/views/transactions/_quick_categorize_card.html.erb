<%# locals: (entry:, transaction:, categories:, ledger_usage: "personal", uncategorized_count: 0) %>
<% lu = local_assigns.fetch(:ledger_usage, "personal") %>
<% qc_remaining = local_assigns.fetch(:uncategorized_count) { Transaction.quick_categorize_uncategorized_count(Current.user, Current.family, ledger_usage: lu) } %>
<% qc_txn = transaction.presence || (entry&.transaction? ? entry.transaction : nil) %>
<% perm = entry && entry.account.permission_for(Current.user) %>
<% full_edit = perm && perm.in?(%i[owner full_control]) %>
<% can_note = perm && perm.in?(%i[owner full_control read_write]) %>
<% if entry.blank? || qc_txn.blank? %>
  <div class="bg-container rounded-2xl shadow-border-xs border border-primary p-10 text-center space-y-4 max-w-lg mx-auto">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-container-inset text-secondary">
      <%= icon "check", size: "lg" %>
    </div>
    <p class="text-primary text-lg font-semibold"><%= t("transactions.quick_categorize.all_done_title") %></p>
    <p class="text-secondary text-sm max-w-sm mx-auto"><%= t("transactions.quick_categorize.all_done_body") %></p>
    <%= render DS::Link.new(
      text: t("transactions.quick_categorize.back_to_list"),
      href: transactions_path(usage: lu),
      variant: "primary",
      frame: "_top"
    ) %>
  </div>
<% else %>
  <div class="space-y-6"
       data-controller="quick-categorize"
       data-quick-categorize-autosave-url-value="<%= transaction_path(entry, usage: lu) %>"
       data-quick-categorize-transaction-id-value="<%= qc_txn.id %>"
       data-quick-categorize-usage-value="<%= lu %>"
       data-quick-categorize-all-categories-text-value="<%= t("transactions.quick_categorize.all_categories_meta", count: categories.size) %>"
       data-quick-categorize-results-count-text-value="<%= t("transactions.quick_categorize.search_results_meta") %>">
    <%# Résumé transaction %>
    <div class="bg-container rounded-2xl shadow-border-xs border border-primary overflow-hidden">
      <div class="bg-container-inset border-b border-primary px-5 py-4">
        <div class="flex flex-wrap items-start justify-between gap-x-3 gap-y-1">
          <p class="text-xs font-medium text-secondary uppercase tracking-wide"><%= t("transactions.quick_categorize.card_heading") %></p>
          <p class="text-xs font-medium text-secondary tabular-nums shrink-0" aria-live="polite">
            <%= t("transactions.quick_categorize.uncategorized_remaining", count: qc_remaining) %>
          </p>
        </div>
        <p class="mt-1 text-lg font-semibold text-primary leading-snug"><%= entry.name %></p>
        <% qc_amount = entry.amount_money.abs %>
        <% if entry.amount.negative? %>
          <p class="mt-2 text-3xl font-semibold tabular-nums tracking-tight privacy-sensitive text-success">
            +<%= format_money(qc_amount) %>
          </p>
        <% else %>
          <p class="mt-2 text-3xl font-semibold tabular-nums tracking-tight privacy-sensitive text-destructive">
            -<%= format_money(qc_amount) %>
          </p>
        <% end %>
        <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1 text-sm text-secondary">
          <span class="inline-flex items-center gap-1.5">
            <%= icon "calendar", size: "sm", class: "text-secondary shrink-0" %>
            <%= l(entry.date, format: :long) %>
          </span>
          <span class="inline-flex items-center gap-1.5">
            <%= icon "landmark", size: "sm", class: "text-secondary shrink-0" %>
            <%= entry.account.name %>
          </span>
          <% if qc_txn.merchant %>
            <span class="inline-flex items-center gap-1.5">
              <%= icon "store", size: "sm", class: "text-secondary shrink-0" %>
              <%= qc_txn.merchant.name %>
            </span>
          <% end %>
        </div>
      </div>

      <% if full_edit %>
        <div class="px-5 py-4 space-y-4 border-b border-primary">
          <%= label_tag "entry_name", t("transactions.quick_categorize.name_label"), class: "text-sm font-medium text-primary" %>
          <%= text_field_tag "entry[name]", entry.name,
                id: "entry_name",
                class: "form-field__input w-full",
                autocomplete: "off",
                data: {
                  quick_categorize_target: "name",
                  action: "input->quick-categorize#scheduleSave"
                } %>
          <%= label_tag "entry_notes", t("transactions.quick_categorize.notes_label"), class: "text-sm font-medium text-primary" %>
          <%= text_area_tag "entry[notes]", entry.notes,
                id: "entry_notes",
                rows: 2,
                class: "form-field__input w-full",
                data: {
                  quick_categorize_target: "notes",
                  action: "input->quick-categorize#scheduleSave"
                } %>
        </div>
      <% elsif can_note %>
        <div class="px-5 py-4 space-y-3 border-b border-primary">
          <%= label_tag "entry_notes", t("transactions.quick_categorize.notes_label"), class: "text-sm font-medium text-primary" %>
          <%= text_area_tag "entry[notes]", entry.notes,
                id: "entry_notes",
                rows: 2,
                class: "form-field__input w-full",
                data: {
                  quick_categorize_target: "notes",
                  action: "input->quick-categorize#scheduleSave"
                } %>
        </div>
      <% end %>

      <%# Catégories %>
      <div class="px-5 py-4 space-y-3">
        <div class="order-2 lg:order-1 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <label for="quick_categorize_search" class="text-sm font-medium text-primary"><%= t("transactions.quick_categorize.pick_category") %></label>
            <p class="text-xs text-secondary mt-0.5"><%= t("transactions.quick_categorize.search_hint") %></p>
          </div>
          <p class="text-xs text-secondary tabular-nums shrink-0" data-quick-categorize-target="resultMeta" aria-live="polite"></p>
        </div>

        <div class="order-3 lg:order-2 relative">
          <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-secondary" aria-hidden="true">
            <%= icon "search", size: "sm" %>
          </span>
          <%= text_field_tag :q, "",
                id: "quick_categorize_search",
                type: "search",
                autocomplete: "off",
                class: "form-field__input w-full pl-10",
                placeholder: t("transactions.quick_categorize.search_placeholder"),
                data: {
                  quick_categorize_target: "search",
                  action: "input->quick-categorize#scheduleFilter keydown->quick-categorize#searchKeydown"
                } %>
        </div>

        <div
          data-quick-categorize-target="categoryList"
          class="order-1 lg:order-3 flex flex-wrap gap-2 lg:block lg:max-h-[min(50vh,22rem)] lg:overflow-y-auto lg:overflow-x-hidden rounded-xl border border-primary bg-container-inset p-2 lg:space-y-1.5"
          role="list"
        >
          <div
            data-quick-categorize-target="emptyState"
            class="hidden w-full rounded-lg border border-dashed border-primary px-4 py-8 text-center space-y-4"
            role="status"
          >
            <p class="text-sm text-secondary"><%= t("transactions.quick_categorize.search_no_results") %></p>
            <p class="text-xs text-secondary"><%= t("transactions.quick_categorize.create_category_hint") %></p>
            <%= form_with url: transaction_category_path(entry),
                  method: :post,
                  data: {
                    turbo_frame: "quick_categorize_card",
                    action: "submit->quick-categorize#prepareCreateCategory"
                  },
                  class: "flex flex-col items-center gap-3" do %>
              <%= hidden_field_tag :quick_categorize, "1" %>
              <%= hidden_field_tag :usage, lu %>
              <%= hidden_field_tag "category[name]", "",
                    data: { quick_categorize_target: "categoryNameField" } %>
              <button
                type="submit"
                class="inline-flex items-center justify-center gap-2 rounded-lg border border-primary bg-container px-4 py-2.5 text-sm font-medium text-primary shadow-border-xs transition-colors hover:bg-surface-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-container focus-visible:ring-gray-400">
                <%= icon "plus", size: "sm", class: "shrink-0" %>
                <%= t("transactions.quick_categorize.create_category_submit") %>
              </button>
            <% end %>
          </div>

          <% categories.each_with_index do |category, idx| %>
            <%= tag.div class: "inline-block lg:block rounded-lg border border-transparent transition-colors", role: "listitem", data: { qc_category: category.name.to_s.downcase, qc_sort: idx } do %>
              <%= button_to transaction_category_path(
                    entry,
                    quick_categorize: "1",
                    usage: lu,
                    entry: {
                      entryable_type: "Transaction",
                      entryable_attributes: { id: qc_txn.id, category_id: category.id }
                    }
                  ),
                  method: :patch,
                  data: { turbo_frame: "quick_categorize_card" },
                  class: "inline-flex w-auto lg:w-full items-center gap-2 lg:gap-3 rounded-full lg:rounded-lg border border-primary lg:border-transparent bg-container lg:bg-transparent px-3 py-1.5 lg:px-3 lg:py-2.5 text-left text-xs lg:text-sm text-primary transition-colors hover:bg-surface-hover hover:border-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-container focus-visible:ring-gray-400" do %>
                <% if category.lucide_icon.present? %>
                  <span class="hidden lg:flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-container border border-primary" style="color: <%= category.color %>">
                    <%= icon category.lucide_icon, size: "sm", color: "current" %>
                  </span>
                <% else %>
                  <span class="hidden lg:flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-container border border-primary text-secondary">
                    <%= icon "tag", size: "sm" %>
                  </span>
                <% end %>
                <span class="min-w-0 flex-1 font-medium truncate whitespace-nowrap" style="color: <%= category.color %>"><%= category.name %></span>
                <%= icon "chevron-right", size: "sm", class: "hidden lg:block text-secondary shrink-0 opacity-60" %>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
