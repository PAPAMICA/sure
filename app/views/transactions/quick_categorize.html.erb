<%= content_for :page_title, t(".page_title") %>

<div class="max-w-2xl mx-auto px-4 sm:px-0 space-y-6 pb-16 pt-2">
  <div class="flex items-center gap-3">
    <%= render DS::Link.new(
      text: t(".back_to_list"),
      icon: "chevron-left",
      href: transactions_path(**with_ledger_usage_url_options),
      variant: "ghost",
      size: :sm
    ) %>
    <div class="h-4 w-px bg-gray-200 theme-dark:bg-gray-700 shrink-0" aria-hidden="true"></div>
    <div class="min-w-0 flex-1">
      <h1 class="text-lg font-semibold text-primary truncate"><%= t(".page_title") %></h1>
      <% if @uncategorized_count.to_i.positive? %>
        <p class="text-xs text-secondary tabular-nums mt-0.5">
          <%= t("transactions.quick_categorize.uncategorized_remaining", count: @uncategorized_count) %>
        </p>
      <% end %>
    </div>
  </div>

  <%= turbo_frame_tag "quick_categorize_card" do %>
    <%= render "transactions/quick_categorize_card",
          entry: @entry,
          transaction: @transaction,
          categories: @categories,
          ledger_usage: @ledger_usage,
          uncategorized_count: @uncategorized_count %>
  <% end %>
</div>
