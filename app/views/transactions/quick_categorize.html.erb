<%= content_for :page_title, t(".page_title") %>

<div class="max-w-2xl mx-auto px-4 sm:px-0 space-y-6 pb-16 pt-2">
  <div class="flex items-center gap-3">
    <%= render DS::Link.new(
      text: t(".back_to_list"),
      icon: "chevron-left",
      href: transactions_path(**with_ledger_usage_url_options),
      variant: "ghost",
      size: :sm
    ) %>
    <div class="h-4 w-px bg-gray-200 theme-dark:bg-gray-700 shrink-0" aria-hidden="true"></div>
    <h1 class="text-lg font-semibold text-primary truncate"><%= t(".page_title") %></h1>
  </div>

  <%= turbo_frame_tag "quick_categorize_card" do %>
    <%= render "transactions/quick_categorize_card",
          entry: @entry,
          transaction: @transaction,
          categories: @categories,
          ledger_usage: @ledger_usage %>
  <% end %>
</div>
