<%# locals: (liquidity_widget:, period:, dashboard_ledger_usage: nil) %>
<% data = liquidity_widget %>
<% total_money = Money.new(data[:total], data[:currency]) %>
<% donut_segments = data[:rows].map { |row|
     {
       id: row[:account]&.id || "other",
       name: row[:account]&.name || row[:name],
       amount: row[:converted_amount].to_f,
       color: row[:color]
     }
   } %>

<section class="bg-container rounded-xl shadow-border-xs border border-primary p-4 lg:p-6 space-y-5">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="space-y-3">
      <div class="space-y-1">
        <p class="text-xs uppercase tracking-wide text-secondary"><%= t("pages.dashboard.liquidity_widget.eyebrow") %></p>
        <h2 class="text-2xl lg:text-3xl font-semibold text-primary privacy-sensitive"><%= format_money(total_money) %></h2>
        <p class="text-sm text-secondary"><%= t("pages.dashboard.liquidity_widget.subtitle") %></p>
      </div>

      <div class="inline-flex rounded-lg border border-primary bg-container-inset p-1">
        <% current_params = request.query_parameters.symbolize_keys %>
        <% include_href = root_path(current_params.merge(liquidity_include_investment_cash: "1")) %>
        <% exclude_href = root_path(current_params.merge(liquidity_include_investment_cash: "0")) %>
        <%= link_to t("pages.dashboard.liquidity_widget.include_investment_cash"),
          include_href,
          class: class_names(
            "px-2.5 py-1.5 rounded-md text-xs font-medium transition-colors",
            data[:include_investment_cash] ? "bg-container text-primary border border-primary" : "text-secondary hover:text-primary"
          ) %>
        <%= link_to t("pages.dashboard.liquidity_widget.exclude_investment_cash"),
          exclude_href,
          class: class_names(
            "px-2.5 py-1.5 rounded-md text-xs font-medium transition-colors",
            data[:include_investment_cash] ? "text-secondary hover:text-primary" : "bg-container text-primary border border-primary"
          ) %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 lg:gap-3 w-full lg:w-auto">
      <% data[:changes].each do |change| %>
        <% positive = change[:delta] >= 0 %>
        <% delta_money = Money.new(change[:delta].abs, data[:currency]) %>
        <div class="rounded-lg border border-primary bg-container-inset px-3 py-2 min-w-[170px]">
          <p class="text-xs text-secondary"><%= t("pages.dashboard.liquidity_widget.change_window", days: change[:days]) %></p>
          <p class="text-sm font-medium <%= positive ? "text-success" : "text-destructive" %> privacy-sensitive">
            <%= positive ? "+" : "-" %><%= format_money(delta_money) %>
          </p>
          <p class="text-xs <%= positive ? "text-success" : "text-destructive" %>">
            <% if change[:pct].nil? %>
              <%= t("pages.dashboard.liquidity_widget.no_reference") %>
            <% else %>
              <%= number_to_percentage(change[:pct], precision: 1) %>
            <% end %>
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <% if data[:rows].any? %>
    <div class="px-1 lg:px-2">
      <div class="flex flex-col lg:flex-row gap-8 items-center">
        <div class="w-full lg:w-1/3 max-w-[300px] px-2">
          <div
            class="h-[300px] relative"
            data-controller="donut-chart"
            data-donut-chart-segments-value="<%= donut_segments.to_json %>"
            data-donut-chart-segment-opacity-value="0.9"
            data-donut-chart-extended-hover-value="true"
            data-donut-chart-hover-extension-value="3"
            data-donut-chart-enable-click-value="false">
            <div data-donut-chart-target="chartContainer" class="absolute inset-0 pointer-events-none"></div>
            <div data-donut-chart-target="contentContainer" class="flex justify-center items-center h-full">
              <div data-donut-chart-target="defaultContent" class="flex flex-col items-center">
                <div class="text-secondary text-sm mb-2">
                  <span><%= t("pages.dashboard.liquidity_widget.distribution") %></span>
                </div>
                <div class="text-3xl font-medium text-primary privacy-sensitive">
                  <%= format_money(total_money) %>
                </div>
              </div>
              <% data[:rows].each do |row| %>
                <% row_id = row[:account]&.id || "other" %>
                <div id="segment_<%= row_id %>" class="hidden">
                  <div class="flex flex-col gap-2 items-center">
                    <p class="text-sm text-secondary"><%= row[:account]&.name || row[:name] %></p>
                    <p class="text-3xl font-medium text-primary privacy-sensitive">
                      <%= format_money(Money.new(row[:converted_amount], data[:currency])) %>
                    </p>
                    <p class="text-sm text-secondary privacy-sensitive"><%= number_to_percentage(row[:weight], precision: 1) %></p>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-2/3 bg-container-inset rounded-xl p-1 space-y-1 overflow-x-auto">
          <div class="px-4 py-2 flex items-center uppercase text-xs font-medium text-secondary">
            <div class="w-28 lg:w-40">
              <p><%= t("pages.dashboard.liquidity_widget.accounts") %><span class="text-subdued mx-1">&middot;</span><%= data[:rows].count %></p>
            </div>
            <div class="ml-auto text-right flex items-center gap-6">
              <div class="w-20 lg:w-40">
                <p><%= t("pages.dashboard.liquidity_widget.available") %></p>
              </div>
              <div class="w-16">
                <p><%= t("pages.dashboard.liquidity_widget.weight") %></p>
              </div>
            </div>
          </div>
          <div class="py-3 shadow-border-xs rounded-lg bg-container font-medium text-sm max-w-full">
            <% data[:rows].each_with_index do |row, idx| %>
              <% row_id = row[:account]&.id || "other" %>
              <% row_money = Money.new(row[:converted_amount], data[:currency]) %>
              <% row_name = row[:account]&.name || row[:name] %>
              <% row_content = capture do %>
                <div class="flex items-center gap-3 flex-1 min-w-0">
                  <div class="h-7 w-7 flex-shrink-0 rounded-full flex justify-center items-center"
                    style="background-color: color-mix(in oklab, <%= row[:color] %> 10%, transparent); color: <%= row[:color] %>;">
                    <% if row[:account].present? %>
                      <%= render "accounts/logo", account: row[:account], size: "sm", color: row[:color] %>
                    <% else %>
                      <%= icon "ellipsis", size: "sm", color: "current" %>
                    <% end %>
                  </div>
                  <span class="text-sm font-medium text-primary truncate"><%= row_name %></span>
                </div>
                <div class="flex items-center gap-4 flex-shrink-0 text-right">
                  <span class="text-sm font-medium text-primary whitespace-nowrap privacy-sensitive"><%= format_money(row_money) %></span>
                  <span class="text-sm text-secondary whitespace-nowrap w-10 lg:w-15 privacy-sensitive"><%= number_to_percentage(row[:weight], precision: 1) %></span>
                </div>
              <% end %>

              <% if row[:account].present? %>
                <%= link_to account_path(row[:account]),
                  class: "flex items-center justify-between mx-3 p-3 rounded-lg cursor-pointer group gap-3",
                  data: {
                    category_id: row_id,
                    action: "mouseenter->donut-chart#highlightSegment mouseleave->donut-chart#unhighlightSegment"
                  } do %>
                  <%= row_content %>
                <% end %>
              <% else %>
                <div class="flex items-center justify-between mx-3 p-3 rounded-lg group gap-3"
                  data-category-id="<%= row_id %>"
                  data-action="mouseenter->donut-chart#highlightSegment mouseleave->donut-chart#unhighlightSegment">
                  <%= row_content %>
                </div>
              <% end %>

              <% if idx < data[:rows].size - 1 %>
                <%= render "shared/ruler", classes: "mx-3 lg:mx-4" %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-primary bg-container-inset p-4">
      <p class="text-sm text-secondary"><%= t("pages.dashboard.liquidity_widget.empty") %></p>
    </div>
  <% end %>

  <div class="rounded-xl border border-primary bg-container-inset p-3 lg:p-4 space-y-3">
    <div class="flex items-center justify-between gap-3">
      <h3 class="text-sm font-medium text-primary"><%= t("pages.dashboard.liquidity_widget.stacked_title") %></h3>
      <%= form_with url: root_path, method: :get, data: { controller: "auto-submit-form", turbo_frame: "_top" } do %>
        <% if local_assigns[:dashboard_ledger_usage].present? %>
          <%= hidden_field_tag :usage, dashboard_ledger_usage %>
        <% end %>
        <%= hidden_field_tag :liquidity_include_investment_cash, data[:include_investment_cash] ? "1" : "0" %>
        <%= render "shared/dashboard_period_selector_fields", period: period %>
      <% end %>
    </div>

    <%= tag.div(
      class: "w-full min-h-64 privacy-sensitive",
      data: {
        controller: "stacked-liquidity-area-chart",
        stacked_liquidity_area_chart_data_value: data[:stacked_chart_data]
      }
    ) %>
  </div>
</section>
