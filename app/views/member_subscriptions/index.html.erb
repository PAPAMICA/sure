<% content_for :page_header do %>
  <div class="space-y-4 mb-6">
    <header class="flex flex-col gap-4 lg:flex-row lg:justify-between lg:items-start text-primary font-medium">
      <div class="space-y-1 flex-1 min-w-0">
        <h1 class="text-xl lg:text-3xl font-medium text-primary">
          <%= t("member_subscriptions.title") %>
        </h1>
        <p class="text-sm lg:text-base text-secondary max-w-2xl">
          <%= t("member_subscriptions.subtitle") %>
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-2 shrink-0">
        <% unless @recurring_disabled %>
          <%= render DS::Link.new(
            text: t("member_subscriptions.detect"),
            icon: "search",
            variant: "primary",
            href: identify_member_subscriptions_path(**with_ledger_usage_url_options),
            data: { turbo_method: :post }
          ) %>
        <% end %>
        <%= render DS::Link.new(
          text: t("member_subscriptions.settings_link"),
          icon: "settings",
          variant: "outline",
          href: recurring_transactions_path,
          data: { turbo_frame: "_top" }
        ) %>
      </div>
    </header>
  </div>
<% end %>

<div class="space-y-6 pb-8 lg:pb-12 flex flex-col">
  <% if @recurring_disabled %>
    <div class="rounded-xl border border-primary bg-container-inset p-4 flex gap-3">
      <%= icon "info", class: "w-5 h-5 text-link shrink-0 mt-0.5" %>
      <p class="text-sm text-secondary"><%= t("member_subscriptions.recurring_disabled") %></p>
    </div>
  <% elsif @recurring.empty? %>
    <div class="bg-container rounded-xl shadow-border-xs border border-primary p-8 text-center space-y-3">
      <%= icon "repeat", size: "xl", class: "text-secondary mx-auto" %>
      <p class="text-primary font-medium"><%= t("member_subscriptions.empty.title") %></p>
      <p class="text-secondary text-sm max-w-md mx-auto"><%= t("member_subscriptions.empty.body") %></p>
      <%= render DS::Link.new(
        text: t("member_subscriptions.detect"),
        icon: "search",
        variant: "primary",
        href: identify_member_subscriptions_path(**with_ledger_usage_url_options),
        data: { turbo_method: :post }
      ) %>
    </div>
  <% else %>
    <% if @subscriptions_donut_data[:categories].present? %>
      <div class="mb-6">
        <%= render "subscriptions_donut", donut_data: @subscriptions_donut_data %>
      </div>
    <% end %>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-container rounded-xl shadow-border-xs border border-primary p-4 lg:p-5">
        <p class="text-xs font-medium uppercase tracking-wide text-secondary"><%= t("member_subscriptions.total_monthly_expenses") %></p>
        <p class="text-2xl lg:text-3xl font-medium text-primary privacy-sensitive mt-1">
          <%= format_money(Money.new(@total_monthly_converted, Current.family.currency)) %>
        </p>
        <p class="text-sm text-secondary mt-2 privacy-sensitive">
          <%= t("member_subscriptions.total_yearly") %>:
          <%= format_money(Money.new(@total_monthly_converted * 12, Current.family.currency)) %>
        </p>
      </div>
      <div class="bg-container rounded-xl shadow-border-xs border border-primary p-4 lg:p-5">
        <p class="text-xs font-medium uppercase tracking-wide text-secondary"><%= t("member_subscriptions.count_label", count: @recurring.size) %></p>
        <p class="text-2xl lg:text-3xl font-medium text-primary mt-1">
          <%= @recurring.size %>
        </p>
        <p class="text-sm text-secondary mt-2">
          <%= t("member_subscriptions.ledger_hint") %>
        </p>
      </div>
    </div>

    <% if @income_recurring_rows.present? %>
      <% income_group_total = @income_recurring_rows.sum { |r| r.converted_monthly_outflow_in_family_currency(Current.family, @rates) } %>
      <section class="bg-container rounded-xl shadow-border-xs border border-primary overflow-hidden">
        <div class="px-4 py-3 lg:px-5 lg:py-4 border-b border-primary flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <div class="flex items-center gap-2 min-w-0">
            <%= icon "wallet", size: "sm", class: "text-success shrink-0" %>
            <h2 class="text-base font-medium text-primary truncate"><%= t("member_subscriptions.income_section_title") %></h2>
          </div>
          <p class="text-sm font-medium text-primary privacy-sensitive whitespace-nowrap">
            <%= t("member_subscriptions.group_total", currency: Current.family.currency) %>:
            <%= format_money(Money.new(income_group_total, Current.family.currency)) %>
          </p>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-left text-xs font-medium text-secondary uppercase tracking-wide border-b border-primary">
                <th class="px-4 py-3 lg:px-5"><%= t("member_subscriptions.table.name") %></th>
                <th class="px-4 py-3 lg:px-5 whitespace-nowrap"><%= t("member_subscriptions.table.amount") %></th>
                <th class="px-4 py-3 lg:px-5 hidden md:table-cell"><%= t("member_subscriptions.table.account") %></th>
                <th class="px-4 py-3 lg:px-5 whitespace-nowrap hidden sm:table-cell"><%= t("member_subscriptions.table.last_charge") %></th>
                <th class="px-4 py-3 lg:px-5 whitespace-nowrap"><%= t("member_subscriptions.table.next_expected") %></th>
              </tr>
            </thead>
            <tbody>
              <% @income_recurring_rows.each do |recurring| %>
                <%= render "recurring_pattern_row", recurring: recurring, rates: @rates %>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>

    <% @category_groups.each do |category, rows| %>
      <% group_total = rows.sum { |r| r.converted_monthly_outflow_in_family_currency(Current.family, @rates) } %>
      <section class="bg-container rounded-xl shadow-border-xs border border-primary overflow-hidden">
        <div class="px-4 py-3 lg:px-5 lg:py-4 border-b border-primary flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <div class="flex items-center gap-2 min-w-0">
            <% if category.present? %>
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-container-inset shrink-0" style="color: <%= category.color %>">
                <% if category.lucide_icon.present? %>
                  <%= icon category.lucide_icon, size: "sm", color: "current" %>
                <% else %>
                  <%= icon "tag", size: "sm" %>
                <% end %>
              </span>
              <h2 class="text-base font-medium text-primary truncate"><%= category.name %></h2>
            <% else %>
              <%= icon "tag", size: "sm", class: "text-secondary shrink-0" %>
              <h2 class="text-base font-medium text-secondary"><%= t("member_subscriptions.uncategorized") %></h2>
            <% end %>
          </div>
          <p class="text-sm font-medium text-primary privacy-sensitive whitespace-nowrap">
            <%= t("member_subscriptions.group_total", currency: Current.family.currency) %>:
            <%= format_money(Money.new(group_total, Current.family.currency)) %>
          </p>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="text-left text-xs font-medium text-secondary uppercase tracking-wide border-b border-primary">
                <th class="px-4 py-3 lg:px-5"><%= t("member_subscriptions.table.name") %></th>
                <th class="px-4 py-3 lg:px-5 whitespace-nowrap"><%= t("member_subscriptions.table.amount") %></th>
                <th class="px-4 py-3 lg:px-5 hidden md:table-cell"><%= t("member_subscriptions.table.account") %></th>
                <th class="px-4 py-3 lg:px-5 whitespace-nowrap hidden sm:table-cell"><%= t("member_subscriptions.table.last_charge") %></th>
                <th class="px-4 py-3 lg:px-5 whitespace-nowrap"><%= t("member_subscriptions.table.next_expected") %></th>
              </tr>
            </thead>
            <tbody>
              <% rows.each do |recurring| %>
                <%= render "recurring_pattern_row", recurring: recurring, rates: @rates %>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    <% end %>
  <% end %>
</div>
