<%= content_for :page_title, t("settings.notifications.show.page_title") %>

<div class="space-y-6 max-w-3xl">
  <p class="text-secondary text-sm">
    <%= t("settings.notifications.show.intro") %>
    <%= link_to t("settings.notifications.show.intro_link_label"), "https://github.com/caronc/apprise", class: "text-primary underline", target: "_blank", rel: "noopener noreferrer" %>.
  </p>

  <%= styled_form_with model: @family, url: settings_notification_path, method: :patch, class: "space-y-8" do |form| %>
    <%= form.text_field :apprise_notify_url,
        label: t("settings.notifications.show.url_label"),
        hint: t("settings.notifications.show.url_hint"),
        value: @family.apprise_notify_url %>

    <% nt = @rules["new_transaction"] %>
    <div class="bg-container rounded-xl shadow-border-xs p-5 space-y-4">
      <h2 class="text-primary font-medium"><%= t("settings.notifications.show.new_tx_heading") %></h2>
      <%= hidden_field_tag "family[apprise_new_transaction_enabled]", "0", id: nil %>
      <%= check_box_tag "family[apprise_new_transaction_enabled]", "1", ActiveModel::Type::Boolean.new.cast(nt["enabled"]), class: "rounded border-primary" %>
      <%= label_tag "family_apprise_new_transaction_enabled", t("settings.notifications.show.new_tx_enable"), class: "text-sm text-primary ml-2" %>

      <div class="pl-1 space-y-3">
        <p class="text-xs text-secondary"><%= t("settings.notifications.show.filter_accounts") %></p>
        <div class="flex flex-wrap gap-3 max-h-40 overflow-y-auto">
          <% @accounts.each do |account| %>
            <% checked = Array(nt["account_ids"]).map(&:to_s).include?(account.id.to_s) %>
            <label class="flex items-center gap-2 text-sm text-primary">
              <%= check_box_tag "family[apprise_new_tx_account_ids][]", account.id, checked, id: "apprise_nt_acct_#{account.id}" %>
              <%= account.name %>
            </label>
          <% end %>
        </div>

        <p class="text-xs text-secondary pt-2"><%= t("settings.notifications.show.filter_categories") %></p>
        <div class="flex flex-wrap gap-3 max-h-40 overflow-y-auto">
          <% @categories.each do |category| %>
            <% checked = Array(nt["category_ids"]).map(&:to_s).include?(category.id.to_s) %>
            <label class="flex items-center gap-2 text-sm text-primary">
              <%= check_box_tag "family[apprise_new_tx_category_ids][]", category.id, checked, id: "apprise_nt_cat_#{category.id}" %>
              <%= category.name %>
            </label>
          <% end %>
        </div>

        <p class="text-xs text-secondary pt-2"><%= t("settings.notifications.show.filter_kinds") %></p>
        <div class="flex flex-wrap gap-3">
          <% Transaction.kinds.each_key do |kind| %>
            <% checked = Array(nt["kinds"]).map(&:to_s).include?(kind.to_s) %>
            <label class="flex items-center gap-2 text-sm text-primary">
              <%= check_box_tag "family[apprise_new_tx_kinds][]", kind, checked, id: "apprise_nt_kind_#{kind}" %>
              <%= kind.to_s.humanize %>
            </label>
          <% end %>
        </div>

        <p class="text-xs text-secondary pt-2"><%= t("settings.notifications.show.filter_flow") %></p>
        <div class="flex flex-wrap gap-3">
          <% %w[income expense transfer].each do |flow| %>
            <% checked = Array(nt["flow_types"]).map(&:to_s).include?(flow) %>
            <label class="flex items-center gap-2 text-sm text-primary">
              <%= check_box_tag "family[apprise_new_tx_flow_types][]", flow, checked, id: "apprise_nt_flow_#{flow}" %>
              <%= t("settings.notifications.show.flow_#{flow}") %>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <% bal = @rules["balance"] %>
    <div class="bg-container rounded-xl shadow-border-xs p-5 space-y-4">
      <h2 class="text-primary font-medium"><%= t("settings.notifications.show.balance_heading") %></h2>
      <%= hidden_field_tag "family[apprise_balance_enabled]", "0", id: nil %>
      <%= check_box_tag "family[apprise_balance_enabled]", "1", ActiveModel::Type::Boolean.new.cast(bal["enabled"]), class: "rounded border-primary" %>
      <%= label_tag "family_apprise_balance_enabled", t("settings.notifications.show.balance_enable"), class: "text-sm text-primary ml-2" %>

      <p class="text-xs text-secondary"><%= t("settings.notifications.show.filter_accounts") %></p>
      <div class="flex flex-wrap gap-3 max-h-40 overflow-y-auto">
        <% @accounts.each do |account| %>
          <% checked = Array(bal["account_ids"]).map(&:to_s).include?(account.id.to_s) %>
          <label class="flex items-center gap-2 text-sm text-primary">
            <%= check_box_tag "family[apprise_balance_account_ids][]", account.id, checked, id: "apprise_bal_acct_#{account.id}" %>
            <%= account.name %>
          </label>
        <% end %>
      </div>
    </div>

    <%= form.submit t("settings.notifications.show.save"), variant: "primary" %>
  <% end %>
</div>
