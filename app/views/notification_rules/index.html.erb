<%= content_for :page_title, t("notification_rules.index.title") %>

<%= content_for :page_actions do %>
  <%= render DS::Menu.new do |menu| %>
    <% menu.with_item(
      variant: "link",
      text: t("notification_rules.index.new_transaction_rule"),
      href: new_notification_rule_path(target: "transaction"),
      icon: "credit-card",
      data: { turbo_frame: :modal }
    ) %>
    <% menu.with_item(
      variant: "link",
      text: t("notification_rules.index.new_balance_rule"),
      href: new_notification_rule_path(target: "balance"),
      icon: "landmark",
      data: { turbo_frame: :modal }
    ) %>
    <% menu.with_item(
      variant: "link",
      text: t("notification_rules.index.new_summary_rule"),
      href: new_notification_rule_path(target: "summary"),
      icon: "chart-column",
      data: { turbo_frame: :modal }
    ) %>
  <% end %>
<% end %>

<div class="space-y-8 max-w-4xl pb-10">
  <div class="text-secondary text-sm space-y-2">
    <p>
      <%= t("notification_rules.index.intro_before_link") %>
      <%= link_to "ntfy", "https://ntfy.sh", class: "text-primary underline", target: "_blank", rel: "noopener noreferrer" %>.
      <%= t("notification_rules.index.intro_after_link") %>
    </p>
    <p class="text-xs">
      <%= t("notification_rules.index.ntfy_auth_doc_prefix") %>
      <%= link_to t("notification_rules.index.ntfy_auth_doc_link"), "https://docs.ntfy.sh/publish/#authentication", class: "text-primary underline", target: "_blank", rel: "noopener noreferrer" %>
      ·
      <%= link_to t("notification_rules.index.ntfy_publish_doc_link"), "https://docs.ntfy.sh/publish/", class: "text-primary underline", target: "_blank", rel: "noopener noreferrer" %>
    </p>
  </div>

  <section aria-labelledby="notification-rules-list-heading">
    <div class="flex items-center justify-between gap-3 mb-3">
      <h2 id="notification-rules-list-heading" class="text-base font-semibold text-primary">
        <%= t("notification_rules.index.list_heading") %>
      </h2>
      <% if @notification_rules.any? %>
        <span class="text-xs text-secondary tabular-nums"><%= @notification_rules.size %></span>
      <% end %>
    </div>

    <div class="bg-container rounded-xl shadow-border-xs p-4">
      <% if @notification_rules.any? %>
        <div class="flex flex-col bg-container rounded-lg shadow-border-xs border border-primary">
          <%= render partial: "notification_rule", collection: @notification_rules, spacer_template: "shared/ruler" %>
        </div>
      <% else %>
        <p class="text-secondary text-sm py-8 text-center"><%= t("notification_rules.index.empty") %></p>
      <% end %>
    </div>
  </section>

  <% if Current.user.admin? %>
    <section aria-labelledby="notification-rules-ntfy-heading" class="space-y-4">
      <div>
        <h2 id="notification-rules-ntfy-heading" class="text-base font-semibold text-primary">
          <%= t("notification_rules.index.ntfy_settings_heading") %>
        </h2>
        <p class="text-xs text-secondary mt-1 max-w-2xl"><%= t("notification_rules.index.ntfy_settings_intro") %></p>
      </div>

      <%= styled_form_with model: Current.family, url: update_family_ntfy_notification_rules_path, method: :patch, class: "space-y-6" do |f| %>
        <article class="bg-container rounded-xl shadow-border-xs border border-primary overflow-hidden">
          <header class="px-4 py-3 border-b border-primary bg-container-inset flex items-center gap-2">
            <%= icon "plug", class: "size-4 text-secondary shrink-0" %>
            <h3 class="text-sm font-medium text-primary"><%= t("notification_rules.index.ntfy_connection_heading") %></h3>
          </header>
          <div class="p-4">
            <%= render "notification_rules/family_ntfy_connection_fields", f: f %>
          </div>
        </article>

        <article class="bg-container rounded-xl shadow-border-xs border border-primary overflow-hidden">
          <header class="px-4 py-3 border-b border-primary bg-container-inset flex items-center gap-2">
            <%= icon "credit-card", class: "size-4 text-secondary shrink-0" %>
            <div>
              <h3 class="text-sm font-medium text-primary"><%= t("notification_rules.index.template_transaction_heading") %></h3>
              <p class="text-xs text-secondary mt-0.5"><%= t("notification_rules.index.templates_intro") %></p>
            </div>
          </header>
          <div class="p-4">
            <%= render "notification_rules/family_ntfy_transaction_section", f: f %>
          </div>
        </article>

        <article class="bg-container rounded-xl shadow-border-xs border border-primary overflow-hidden">
          <header class="px-4 py-3 border-b border-primary bg-container-inset flex items-center gap-2">
            <%= icon "landmark", class: "size-4 text-secondary shrink-0" %>
            <div>
              <h3 class="text-sm font-medium text-primary"><%= t("notification_rules.index.template_balance_heading") %></h3>
              <p class="text-xs text-secondary mt-0.5"><%= t("notification_rules.index.templates_intro") %></p>
            </div>
          </header>
          <div class="p-4">
            <%= render "notification_rules/family_ntfy_balance_section", f: f %>
          </div>
        </article>

        <article class="bg-container rounded-xl shadow-border-xs border border-primary overflow-hidden">
          <header class="px-4 py-3 border-b border-primary bg-container-inset flex items-center gap-2">
            <%= icon "chart-column", class: "size-4 text-secondary shrink-0" %>
            <div>
              <h3 class="text-sm font-medium text-primary"><%= t("notification_rules.index.template_summary_heading") %></h3>
              <p class="text-xs text-secondary mt-0.5"><%= t("notification_rules.index.templates_intro") %></p>
            </div>
          </header>
          <div class="p-4">
            <%= render "notification_rules/family_ntfy_summary_section", f: f %>
          </div>
        </article>

        <div class="flex flex-wrap items-center gap-3 pt-1">
          <%= render DS::Button.new(
                text: t("notification_rules.index.save_ntfy_settings"),
                variant: :primary,
                type: "submit",
                name: "family_action",
                value: "save"
              ) %>
          <%= render DS::Button.new(
                text: t("notification_rules.test.send_button"),
                variant: :secondary,
                type: "submit",
                name: "family_action",
                value: "test_ntfy"
              ) %>
        </div>
        <p class="text-xs text-secondary"><%= t("notification_rules.test.inline_hint") %></p>
      <% end %>
    </section>
  <% end %>
</div>
