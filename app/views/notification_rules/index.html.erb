<%= content_for :page_title, t("notification_rules.index.title") %>

<%= content_for :page_actions do %>
  <%= render DS::Menu.new do |menu| %>
    <% menu.with_item(
      variant: "link",
      text: t("notification_rules.index.new_transaction_rule"),
      href: new_notification_rule_path(target: "transaction"),
      icon: "credit-card",
      data: { turbo_frame: :modal }
    ) %>
    <% menu.with_item(
      variant: "link",
      text: t("notification_rules.index.new_balance_rule"),
      href: new_notification_rule_path(target: "balance"),
      icon: "landmark",
      data: { turbo_frame: :modal }
    ) %>
    <% menu.with_item(
      variant: "link",
      text: t("notification_rules.index.new_summary_rule"),
      href: new_notification_rule_path(target: "summary"),
      icon: "chart-column",
      data: { turbo_frame: :modal }
    ) %>
  <% end %>
<% end %>

<div class="space-y-6 max-w-4xl">
  <p class="text-secondary text-sm">
    <%= t("notification_rules.index.intro_before_link") %>
    <%= link_to "ntfy", "https://ntfy.sh", class: "text-primary underline", target: "_blank", rel: "noopener noreferrer" %>.
    <%= t("notification_rules.index.intro_after_link") %>
    <%= t("notification_rules.index.ntfy_auth_doc_prefix") %>
    <%= link_to t("notification_rules.index.ntfy_auth_doc_link"), "https://docs.ntfy.sh/publish/#authentication", class: "text-primary underline", target: "_blank", rel: "noopener noreferrer" %>.
  </p>

  <% if Current.user.admin? %>
    <div class="bg-container rounded-xl shadow-border-xs p-4 space-y-6">
      <div>
        <h2 class="text-sm font-medium text-primary"><%= t("notification_rules.index.ntfy_settings_heading") %></h2>
        <p class="text-xs text-secondary mt-1"><%= t("notification_rules.index.ntfy_settings_intro") %></p>
      </div>

      <%= styled_form_with model: Current.family, url: update_family_ntfy_notification_rules_path, method: :patch, class: "space-y-5" do |f| %>
        <div class="space-y-3">
          <h3 class="text-xs font-medium text-secondary uppercase tracking-wide"><%= t("notification_rules.index.ntfy_connection_heading") %></h3>
          <%= f.text_field :ntfy_url, label: t("notification_rules.index.default_url_label"), value: Current.family.ntfy_url %>
          <p class="text-xs text-secondary"><%= t("notification_rules.index.ntfy_auth_hint") %></p>
          <%= f.text_field :ntfy_access_token,
                label: t("notification_rules.index.ntfy_access_token_label"),
                value: "",
                placeholder: t("notification_rules.index.secret_placeholder"),
                hint: t("notification_rules.index.ntfy_token_family_hint") %>
          <%= f.text_field :ntfy_basic_username,
                label: t("notification_rules.index.ntfy_basic_username_label"),
                value: Current.family.ntfy_basic_username,
                hint: t("notification_rules.index.ntfy_basic_username_hint") %>
          <%= f.password_field :ntfy_basic_password,
                label: t("notification_rules.index.ntfy_basic_password_label"),
                value: "",
                placeholder: t("notification_rules.index.secret_placeholder"),
                hint: t("notification_rules.index.ntfy_password_family_hint") %>
          <div class="flex items-center gap-2">
            <%= check_box_tag "family[clear_ntfy_credentials]", "1", false, id: "family_clear_ntfy_credentials" %>
            <%= label_tag "family_clear_ntfy_credentials", t("notification_rules.index.clear_ntfy_credentials_label"), class: "text-sm text-primary" %>
          </div>
        </div>

        <div class="space-y-3 border-t border-primary pt-5">
          <h3 class="text-xs font-medium text-secondary uppercase tracking-wide"><%= t("notification_rules.index.templates_heading") %></h3>
          <p class="text-xs text-secondary"><%= t("notification_rules.index.templates_intro") %></p>

          <div class="space-y-2">
            <p class="text-xs font-medium text-primary"><%= t("notification_rules.index.template_transaction_heading") %></p>
            <pre class="text-xs text-secondary whitespace-pre-wrap font-mono bg-container-inset rounded-lg p-3 border border-primary"><%= t("notification_rules.index.template_variables_transaction") %></pre>
            <%= f.text_area :ntfy_transaction_title_template,
                  label: t("notification_rules.index.template_transaction_title_label"),
                  value: Current.family.ntfy_transaction_title_template,
                  rows: 2,
                  class: "form-field__input w-full font-mono text-sm",
                  hint: t("notification_rules.index.template_leave_blank_hint") %>
            <%= f.text_area :ntfy_transaction_body_template,
                  label: t("notification_rules.index.template_transaction_body_label"),
                  value: Current.family.ntfy_transaction_body_template,
                  rows: 6,
                  class: "form-field__input w-full font-mono text-sm" %>
          </div>

          <div class="space-y-2">
            <p class="text-xs font-medium text-primary"><%= t("notification_rules.index.template_balance_heading") %></p>
            <%= f.number_field :ntfy_balance_prior_days,
                  label: t("notification_rules.index.ntfy_balance_prior_days_label"),
                  min: 0,
                  max: 365,
                  step: 1,
                  class: "form-field__input w-full max-w-xs",
                  hint: t("notification_rules.index.ntfy_balance_prior_days_hint") %>
            <pre class="text-xs text-secondary whitespace-pre-wrap font-mono bg-container-inset rounded-lg p-3 border border-primary"><%= t("notification_rules.index.template_variables_balance") %></pre>
            <%= f.text_area :ntfy_balance_title_template,
                  label: t("notification_rules.index.template_balance_title_label"),
                  value: Current.family.ntfy_balance_title_template,
                  rows: 2,
                  class: "form-field__input w-full font-mono text-sm",
                  hint: t("notification_rules.index.template_leave_blank_hint") %>
            <%= f.text_area :ntfy_balance_body_template,
                  label: t("notification_rules.index.template_balance_body_label"),
                  value: Current.family.ntfy_balance_body_template,
                  rows: 5,
                  class: "form-field__input w-full font-mono text-sm" %>
          </div>

          <div class="space-y-2">
            <p class="text-xs font-medium text-primary"><%= t("notification_rules.index.template_summary_heading") %></p>
            <pre class="text-xs text-secondary whitespace-pre-wrap font-mono bg-container-inset rounded-lg p-3 border border-primary"><%= t("notification_rules.index.template_variables_summary") %></pre>
            <%= f.text_area :ntfy_summary_title_template,
                  label: t("notification_rules.index.template_summary_title_label"),
                  value: Current.family.ntfy_summary_title_template,
                  rows: 2,
                  class: "form-field__input w-full font-mono text-sm",
                  hint: t("notification_rules.index.template_leave_blank_hint") %>
            <%= f.text_area :ntfy_summary_body_template,
                  label: t("notification_rules.index.template_summary_body_label"),
                  value: Current.family.ntfy_summary_body_template,
                  rows: 8,
                  class: "form-field__input w-full font-mono text-sm" %>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-3 pt-2">
          <%= render DS::Button.new(
                text: t("notification_rules.index.save_ntfy_settings"),
                variant: :primary,
                type: "submit",
                name: "family_action",
                value: "save"
              ) %>
          <%= render DS::Button.new(
                text: t("notification_rules.test.send_button"),
                variant: :secondary,
                type: "submit",
                name: "family_action",
                value: "test_ntfy"
              ) %>
        </div>
        <p class="text-xs text-secondary"><%= t("notification_rules.test.inline_hint") %></p>
      <% end %>
    </div>
  <% end %>

  <div class="bg-container rounded-xl shadow-border-xs p-4">
    <% if @notification_rules.any? %>
      <div class="bg-container-inset rounded-xl">
        <div class="flex justify-between px-4 py-2 text-xs uppercase font-medium text-secondary">
          <span><%= t("notification_rules.index.list_heading") %> · <%= @notification_rules.size %></span>
        </div>
        <div class="p-1">
          <div class="flex flex-col bg-container rounded-lg shadow-border-xs">
            <%= render partial: "notification_rule", collection: @notification_rules, spacer_template: "shared/ruler" %>
          </div>
        </div>
      </div>
    <% else %>
      <p class="text-secondary text-sm py-8 text-center"><%= t("notification_rules.index.empty") %></p>
    <% end %>
  </div>
</div>
