<%# locals: (f:, field:, label:, hint:) %>
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 py-3 border-b border-primary last:border-b-0">
  <div class="min-w-0 flex-1">
    <p class="text-sm font-medium text-primary"><%= label %></p>
    <p class="text-xs text-secondary mt-0.5"><%= hint %></p>
  </div>
  <div class="shrink-0">
    <%= f.toggle field, label: false %>
  </div>
</div>
